# Zugangsdaten für den beim ersten Start automatisch angelegten Admin-Account.
# Diese Datei nach .env kopieren und eigene Werte eintragen:
#   cp .env.example .env
#
# WICHTIG: Die echte .env-Datei niemals committen (steht in .gitignore).

ROADMAP_ADMIN_USER=admin
ROADMAP_ADMIN_PASSWORD=bitte-ein-sicheres-passwort-setzen

# Domain für HTTPS (Caddy holt automatisch ein Let's-Encrypt-Zertifikat).
# Der DNS-Eintrag (A-Record) muss auf die Server-IP zeigen.
ROADMAP_DOMAIN=roadmap.example.com
